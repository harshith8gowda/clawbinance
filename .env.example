# ClawBinance — Environment Configuration
# Copy this file to .env and fill in your API keys

# ===========================================
# BINANCE API (Required)
# Get from: https://www.binance.com/en/my/settings/api-management
# IMPORTANT: Use "Enable Futures" but DO NOT enable "Enable Withdrawals"
# ===========================================
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_secret_here

# ===========================================
# TELEGRAM BOT (Required for notifications)
# Create bot with @BotFather on Telegram
# ===========================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ===========================================
# X/TWITTER API (Optional — for social sharing)
# Get from: https://developer.twitter.com/en/portal/dashboard
# ===========================================
X_API_KEY=optional_x_api_key
X_API_SECRET=optional_x_secret
X_ACCESS_TOKEN=optional_x_access_token
X_ACCESS_TOKEN_SECRET=optional_x_access_secret

# ===========================================
# OPENCLAW (Optional — for autonomous execution)
# ===========================================
OPENCLAW_API_KEY=optional_openclaw_key

# ===========================================
# TRADING CONFIGURATION (Optional)
# ===========================================
# Risk per trade (default: 1% of account)
RISK_PER_TRADE=0.01

# Z-Score threshold (default: 2.0)
ZSCORE_THRESHOLD=2.0

# Lookback period for Z-Score (default: 50 periods)
ZSCORE_LOOKBACK=50

# Symbols to monitor (comma-separated)
TRADING_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,XRPUSDT
